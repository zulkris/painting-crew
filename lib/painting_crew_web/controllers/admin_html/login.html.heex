<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Вход в админ-панель</title>
  <link phx-track-static rel="stylesheet" href={~p"/assets/app.css"} />
</head>
<body class="bg-primary-50 min-h-screen flex items-center justify-center">
  <div class="bg-white rounded-2xl shadow-lg p-8 w-full max-w-sm">
    <h1 class="font-display text-2xl font-bold text-primary-900 mb-6 text-center">Вход в админ-панель</h1>

    <%= if Phoenix.Flash.get(@flash, :error) do %>
      <div class="mb-4 p-3 rounded-lg bg-accent-50 text-accent-700 text-sm font-medium">
        <%= Phoenix.Flash.get(@flash, :error) %>
      </div>
    <% end %>

    <form action={~p"/admin/login"} method="post">
      <input type="hidden" name="_csrf_token" value={Phoenix.Controller.get_csrf_token()} />
      <div class="mb-4">
        <label for="user" class="block text-sm font-medium text-primary-700 mb-1">Логин</label>
        <input id="user" name="user" type="text" required autocomplete="username"
          class="w-full px-4 py-3 rounded-xl border border-primary-200 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent text-sm" />
      </div>
      <div class="mb-6">
        <label for="pass" class="block text-sm font-medium text-primary-700 mb-1">Пароль</label>
        <input id="pass" name="pass" type="password" required autocomplete="current-password"
          class="w-full px-4 py-3 rounded-xl border border-primary-200 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent text-sm" />
      </div>
      <button type="submit"
        class="w-full py-3 rounded-xl bg-primary hover:bg-primary-700 text-white font-bold text-sm transition-colors">
        Войти
      </button>
    </form>
  </div>
</body>
</html>
